rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Email-verified guard ───────────────────────────────────
    // 2026-05-25: writes now require request.auth.token.email_verified.
    // Google sign-in carries this token automatically (Google verifies
    // the email at signup). Email/password signups must click the
    // verification link before they can write to Firestore. Reads stay
    // open to any authenticated owner so users can still see what they
    // already have (and to avoid lockouts during the verification gap).
    //
    // IMPORTANT: this is the server-side enforcement layer. Client-side
    // gates (Aura.requireVerifiedEmail) handle UX; this rule is the
    // guarantee that a determined user with the JS console can't bypass.
    //
    // NOTE: firestore.rules is NOT auto-deployed by the Netlify
    // pipeline. After this commit, run:
    //   firebase deploy --only firestore:rules
    // from the project root to push the rule change live.
    function isVerified() {
      return request.auth != null
        && request.auth.token.email_verified == true;
    }

    // ── User profiles & quiz results ────────────────────────────
    // Only the authenticated owner can read/write their own document,
    // and they can NEVER touch the `isAdmin` field from a client SDK.
    // isAdmin is set/revoked exclusively via the Firebase Console (Admin
    // SDK bypasses these rules), so self-promotion is impossible no
    // matter what the client sends.
    match /users/{userId} {
      // Read stays available to any authenticated owner — avoids
      // breaking users who exist but haven't verified yet (they can
      // still see their own profile to figure out what's pending).
      allow read: if request.auth != null && request.auth.uid == userId;

      // Create: owner only, must be email-verified, and the new doc
      // cannot ship with isAdmin set.
      allow create: if isVerified()
        && request.auth.uid == userId
        && !('isAdmin' in request.resource.data);

      // Update: owner only, must be email-verified, and isAdmin must
      // not be among the affected keys. (Updating other fields when
      // isAdmin is already true is fine — value isn't in the diff
      // because it didn't change.)
      allow update: if isVerified()
        && request.auth.uid == userId
        && !('isAdmin' in request.resource.data.diff(resource.data).affectedKeys());

      allow delete: if isVerified() && request.auth.uid == userId;
    }

    // ── Moodboard saved looks ────────────────────────────────────
    match /moodboards/{userId}/items/{itemId} {
      // Read: any authenticated owner (lets existing unverified
      // accounts still see what they had previously saved).
      allow read: if request.auth != null && request.auth.uid == userId;
      // Write: owner + email-verified only.
      allow write: if isVerified() && request.auth.uid == userId;
    }

    // ── Community circles ────────────────────────────────────────
    // Access is gated by the user's CURRENT saved quiz result.
    //
    // INVARIANT: a user belongs to exactly one community at any moment
    // — the community whose id matches users/{uid}.quizResult.id RIGHT
    // NOW. Retaking the quiz overwrites quizResult.id, which immediately
    // revokes access to every other community (including the previous
    // one). This invariant is enforced server-side here, so client-side
    // caches or stale UI cannot leak access to a previous group.
    //
    // userAesthetic() reads the live users/{uid}.quizResult.id on every
    // rule evaluation. If the user has no quiz result the field read
    // throws → denies access. Old aesthetic IDs are denied because they
    // simply don't equal the current id any more.
    function userAesthetic() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid))
               .data.quizResult.id;
    }

    // True iff the signed-in user has been granted admin in Firestore.
    // Reads `users/{uid}.isAdmin`. Missing field → null → != true → false.
    // The field can only be set via the Firebase Console (Admin SDK), so
    // this is server-trusted.
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid))
               .data.isAdmin == true;
    }

    // Either an admin (full bypass) or a quiz-member of this specific circle.
    // `||` short-circuits so admins without a quiz result don't crash on
    // userAesthetic()'s nested field read.
    function canAccessCommunity(aestheticId) {
      return isAdmin() || userAesthetic() == aestheticId;
    }

    match /communities/{aestheticId}/posts/{postId} {

      // Read: admin OR quiz-member of this circle (auth required;
      // verification not required for reads so existing unverified
      // accounts can still see what's in their circle).
      allow read: if request.auth != null
        && canAccessCommunity(aestheticId);

      // Create: must be email-verified AND a quiz-member of this circle,
      // author must be self, aestheticId must match the URL, content
      // must be a non-empty string ≤ 1 000 chars.
      allow create: if isVerified()
        && canAccessCommunity(aestheticId)
        && request.resource.data.authorId   == request.auth.uid
        && request.resource.data.aestheticId == aestheticId
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 1000;

      // Update: post owner edits — OR — any verified member (or admin)
      // toggles a reaction. Both branches require email verification.
      allow update: if isVerified()
        && canAccessCommunity(aestheticId)
        && (
          resource.data.authorId == request.auth.uid
          ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
        );

      // Delete: post author + email-verified + still has access, OR
      // any admin (server-trusted users/{uid}.isAdmin === true). Admins
      // can moderate abusive content in any circle without needing to
      // be the original author. The isAdmin() check is the same one
      // used by canAccessCommunity() above — server-side only, no
      // client-spoofable email comparison.
      allow delete: if isVerified()
        && (
          (resource.data.authorId == request.auth.uid && canAccessCommunity(aestheticId))
          || isAdmin()
        );

      // ── Comments ──────────────────────────────────────────────
      match /comments/{commentId} {

        allow read: if request.auth != null
          && canAccessCommunity(aestheticId);

        allow create: if isVerified()
          && canAccessCommunity(aestheticId)
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 400;

        // Delete: comment author OR admin (moderation). Same pattern as
        // posts above — admins can remove abusive comments instantly.
        allow delete: if isVerified()
          && (
            (resource.data.authorId == request.auth.uid && canAccessCommunity(aestheticId))
            || isAdmin()
          );
      }
    }

    // ── Admin-only analytics events ──────────────────────────────
    // Lightweight append-only log used by admin-report.html. Documents
    // are written by every visitor (guest or authed) on key UX events
    // (page_view, shop_click, signup_modal_open, etc.).
    //
    // Security model:
    //   • Anyone may CREATE a single event, but the schema is strictly
    //     validated to block spam / payload abuse. Event types are a
    //     whitelist; strings are length-capped; no extra fields allowed.
    //   • Only admins may READ. Normal users (and guests) get
    //     permission-denied if they try to query the collection — even
    //     for their own events.
    //   • Only admins may DELETE, and only events explicitly marked as
    //     test=true. There is no bulk-delete by design.
    //   • UPDATES are never allowed. Events are immutable once written.
    //
    // Schema (strict — extra fields are rejected by hasOnly):
    //   type        string (whitelist below, ≤60 chars)
    //   ts          server timestamp (request.time) — clients can't backdate
    //   sessionId   string ≤60 chars (per-tab guest id; not PII)
    //   isGuest     bool
    //   uid         string ≤128 chars OR null
    //   email       string ≤200 chars OR null  (signed-in user's own email)
    //   isAdmin     bool OR missing
    //   lang        string ≤4 chars ('en','es','ar','he') OR missing
    //   rtl         bool OR missing
    //   device      string ≤16 chars ('mobile'/'desktop'/'tablet') OR missing
    //   browser     string ≤16 chars OR missing
    //   os          string ≤16 chars OR missing
    //   inApp       string ≤24 chars OR null OR missing
    //   path        string ≤200 chars OR missing
    //   referrer    string ≤300 chars OR null OR missing
    //   aesthetic   string ≤32 chars OR null OR missing
    //   outfitIndex number 0-99 OR null OR missing
    //   category    string ≤40 chars OR null OR missing
    //   retailer    string ≤80 chars OR null OR missing
    //   shopUrl     string ≤600 chars OR null OR missing
    //   source      string ≤32 chars OR null OR missing
    //   quizResultId  string ≤32 chars OR null OR missing
    //   quizQuestionIndex  number 0-99 OR null OR missing
    //   modalAction string ≤32 chars OR null OR missing
    //   modalReason string ≤32 chars OR null OR missing
    //   metadata    map OR missing  (small flexible bucket — capped via size)
    //   test        bool OR missing
    function validAnalyticsEvent() {
      let r = request.resource.data;
      let allowed = ['type','ts','sessionId','isGuest','uid','email','isAdmin',
                     'isMaintenanceMode','isMaintenanceScreen','host',
                     'lang','rtl','device','browser','os','inApp','path','referrer',
                     'aesthetic','outfitIndex','category','retailer','shopUrl','source',
                     'quizResultId','quizQuestionIndex','modalAction','modalReason',
                     'metadata','test'];
      let types = ['page_view','aesthetic_view','shop_click','shop_gate_open',
                   'save_click','save_success','save_gate_open',
                   'quiz_start','quiz_complete','quiz_abandoned',
                   'community_view','community_post','community_comment','community_reaction',
                   'signup_modal_open','signup_modal_action',
                   'lang_change','admin_login','admin_login_failed',
                   'maintenance_view',
                   'error','test'];
      return r.keys().hasOnly(allowed)
        && r.type is string && r.type in types
        && r.ts == request.time
        && r.sessionId is string && r.sessionId.size() > 0 && r.sessionId.size() <= 60
        && r.isGuest is bool
        && (r.uid == null || (r.uid is string && r.uid.size() <= 128))
        && (!('email' in r) || r.email == null || (r.email is string && r.email.size() <= 200))
        && (!('isAdmin' in r) || r.isAdmin is bool)
        && (!('isMaintenanceMode' in r) || r.isMaintenanceMode is bool)
        && (!('isMaintenanceScreen' in r) || r.isMaintenanceScreen is bool)
        && (!('host' in r) || r.host == null || (r.host is string && r.host.size() <= 80))
        && (!('lang' in r) || (r.lang is string && r.lang.size() <= 4))
        && (!('rtl' in r) || r.rtl is bool)
        && (!('device' in r) || (r.device is string && r.device.size() <= 16))
        && (!('browser' in r) || (r.browser is string && r.browser.size() <= 16))
        && (!('os' in r) || (r.os is string && r.os.size() <= 16))
        && (!('inApp' in r) || r.inApp == null || (r.inApp is string && r.inApp.size() <= 24))
        && (!('path' in r) || (r.path is string && r.path.size() <= 200))
        && (!('referrer' in r) || r.referrer == null || (r.referrer is string && r.referrer.size() <= 300))
        && (!('aesthetic' in r) || r.aesthetic == null || (r.aesthetic is string && r.aesthetic.size() <= 32))
        && (!('outfitIndex' in r) || r.outfitIndex == null || (r.outfitIndex is int && r.outfitIndex >= 0 && r.outfitIndex < 100))
        && (!('category' in r) || r.category == null || (r.category is string && r.category.size() <= 40))
        && (!('retailer' in r) || r.retailer == null || (r.retailer is string && r.retailer.size() <= 80))
        && (!('shopUrl' in r) || r.shopUrl == null || (r.shopUrl is string && r.shopUrl.size() <= 600))
        && (!('source' in r) || r.source == null || (r.source is string && r.source.size() <= 32))
        && (!('quizResultId' in r) || r.quizResultId == null || (r.quizResultId is string && r.quizResultId.size() <= 32))
        && (!('quizQuestionIndex' in r) || r.quizQuestionIndex == null || (r.quizQuestionIndex is int && r.quizQuestionIndex >= 0 && r.quizQuestionIndex < 100))
        && (!('modalAction' in r) || r.modalAction == null || (r.modalAction is string && r.modalAction.size() <= 32))
        && (!('modalReason' in r) || r.modalReason == null || (r.modalReason is string && r.modalReason.size() <= 32))
        && (!('metadata' in r) || r.metadata is map)
        && (!('test' in r) || r.test is bool);
    }

    match /analytics_events/{eventId} {
      allow create: if validAnalyticsEvent();
      allow read:   if request.auth != null && isAdmin();
      allow delete: if request.auth != null && isAdmin()
                    && resource.data.test == true;
      allow update: if false;
    }

    // ── Waitlist (maintenance-page email capture) ────────────────
    // Open create (guests can subscribe; that's the whole point) but
    // with a strict schema so the collection can't be used as a
    // free-form spam dump. Reads + deletes are admin-only; updates
    // are never allowed.
    //
    // Schema:
    //   email   string lowercase, <= 200 chars, must look like an email
    //   ts      server timestamp (request.time) — clients can't backdate
    //   lang    string <= 4 chars  ('en'/'es'/'ar'/'he')
    //   source  string <= 32 chars (e.g. 'maintenance')
    //   path    string <= 200 chars (entry path for attribution)
    //
    // No `uid`, no `name`, no extras — keeps PII surface minimal.
    function validWaitlistEntry() {
      let r = request.resource.data;
      let allowed = ['email','ts','lang','source','path'];
      return r.keys().hasOnly(allowed)
        && r.email is string
        && r.email.size() > 0 && r.email.size() <= 200
        && r.email.lower() == r.email
        && r.email.matches('[^@\\s]+@[^@\\s]+\\.[^@\\s]+')
        && r.ts == request.time
        && r.lang is string && r.lang.size() > 0 && r.lang.size() <= 4
        && r.source is string && r.source.size() > 0 && r.source.size() <= 32
        && r.path is string && r.path.size() <= 200;
    }

    match /waitlist/{entryId} {
      allow create: if validWaitlistEntry();
      allow read:   if request.auth != null && isAdmin();
      allow delete: if request.auth != null && isAdmin();
      allow update: if false;
    }

    // ── Deny everything else ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
